DATABASE_URL="your_database_connection_string_here"

# ── Better Auth ───────────────────────────────────────────────────────────────
# Root URL of your app. better-auth uses this to build OAuth redirect URIs:
#   {BETTER_AUTH_URL}/api/auth/callback/{provider}
# Production: https://www.greenchainz.com
# Development: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
AUTH_SECRET="your_super_secret_auth_secret_here"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Redirect URI to register: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# ── LinkedIn OAuth ────────────────────────────────────────────────────────────
# Redirect URI to register: {BETTER_AUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID="your_linkedin_client_id_here"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret_here"

# ── Microsoft Entra ID ────────────────────────────────────────────────────────
# Used for: (1) user login, (2) Microsoft Marketplace API calls
# Redirect URI to register in Entra: {BETTER_AUTH_URL}/api/auth/callback/microsoft
# Remove from Entra: /.auth/login/aad/callback (Easy Auth — no longer used)
AZURE_CLIENT_ID="your_azure_ad_client_id_here"
AZURE_CLIENT_SECRET="your_azure_ad_client_secret_here"
AZURE_TENANT_ID="your_azure_ad_tenant_id_here"

# Generate with: openssl rand -base64 32
AUTH_SECRET="your_super_secret_auth_secret_here"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Redirect URI to register: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# ── LinkedIn OAuth ────────────────────────────────────────────────────────────
# Redirect URI to register: {BETTER_AUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID="your_linkedin_client_id_here"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret_here"

# ── Microsoft Entra ID ────────────────────────────────────────────────────────
# Used for: (1) user login, (2) Microsoft Marketplace API calls
# Redirect URI to register in Entra: {BETTER_AUTH_URL}/api/auth/callback/microsoft
# Remove from Entra: /.auth/login/aad/callback (Easy Auth — no longer used)
AZURE_CLIENT_ID="your_azure_ad_client_id_here"
AZURE_CLIENT_SECRET="your_azure_ad_client_secret_here"
AZURE_TENANT_ID="your_azure_ad_tenant_id_here"
# Better Auth
# You can generate a secret with `openssl rand -base64 32`
AUTH_SECRET="your_super_secret_auth_secret_here"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# LinkedIn OAuth
LINKEDIN_CLIENT_ID="your_linkedin_client_id_here"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret_here"

# Microsoft Entra ID (for user login AND Marketplace API)
AZURE_CLIENT_ID_APP="your_azure_ad_app_client_id_here"
AZURE_CLIENT_SECRET_APP="your_azure_ad_app_client_secret_here"
AZURE_TENANT_ID_APP="your_azure_ad_app_tenant_id_here"
