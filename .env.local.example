# ============================================
# LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# ============================================
#
# Copy this file to .env.local and fill in your actual values
# cp .env.local.example .env.local
#
# ⚠️  DO NOT COMMIT .env.local - it should be in .gitignore
#
# ============================================

# ============================================
# AZURE EASY AUTH (Local Development)
# ============================================

# For local development, Easy Auth headers are not available
# Use test/mock headers or run the app through Azure Container Apps dev container
# See docs/EASY_AUTH_INTEGRATION.md for local testing strategies

# Optional: Azure AD credentials for local testing
AZURE_AD_CLIENT_ID=your_azure_ad_app_client_id
AZURE_AD_CLIENT_SECRET=your_azure_ad_client_secret
AZURE_AD_TENANT_ID=your-tenant-id

# ============================================
# DATABASE (Local Development)
# ============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/greenchainz_dev

# ============================================
# OPTIONAL: Additional Configuration
# ============================================

# Node environment
NODE_ENV=development

# Backend URL (if using separate backend)
BACKEND_URL=http://localhost:3001
