// Swap Engine Tables for PostgreSQL
// This schema extends the existing Prisma schema with swap validation infrastructure

model MaterialTechnicalSpec {
  id        Int      @id @default(autoincrement())
  materialId Int     @map("material_id")
  
  // ASTM Standards (JSON array)
  astmCodes String[] @default([]) @map("astm_codes")
  
  // Fire & Safety Certifications
  ulListing          String? @map("ul_listing") @db.VarChar(255)
  ulDesignNumber     String? @map("ul_design_number") @db.VarChar(50)
  iccEsReport        String? @map("icc_es_report") @db.VarChar(50)
  fireRating         String? @map("fire_rating") @db.VarChar(50)
  fireRatingStandard String? @map("fire_rating_standard") @db.VarChar(100)
  charRate           String? @map("char_rate") @db.VarChar(50)
  
  // Structural Performance
  compressiveStrengthPsi Int? @map("compressive_strength_psi")
  modulusOfElasticityKsi Int? @map("modulus_of_elasticity_ksi")
  flexuralStrengthPsi    Int? @map("flexural_strength_psi")
  tensileStrengthPsi     Int? @map("tensile_strength_psi")
  stiffnessKsi           Int? @map("stiffness_ksi")
  
  // Thermal Performance
  rValuePerInch Decimal? @map("r_value_per_inch") @db.Decimal(5, 2)
  lttr15Year    Decimal? @map("lttr_15_year") @db.Decimal(5, 2)
  permRating    Decimal? @map("perm_rating") @db.Decimal(5, 2)
  thermalUValue Decimal? @map("thermal_u_value") @db.Decimal(8, 4)
  
  // Acoustic Performance
  stcRating Int?     @map("stc_rating")
  iicRating Int?     @map("iic_rating")
  nrcRating Decimal? @map("nrc_rating") @db.Decimal(3, 2)
  
  // Installability & Labor
  laborUnits             Decimal? @map("labor_units") @db.Decimal(5, 2)
  cureTimeHours          Int?     @map("cure_time_hours")
  weightPerUnit          Decimal? @map("weight_per_unit") @db.Decimal(8, 2)
  slumpWorkability       String?  @map("slump_workability") @db.VarChar(50)
  installationDifficulty Int?     @map("installation_difficulty")
  
  // Reliability & Supply Chain
  leadTimeDays      Int?     @map("lead_time_days")
  otifPercentage    Decimal? @map("otif_percentage") @db.Decimal(5, 2)
  supplierZScore    Decimal? @map("supplier_z_score") @db.Decimal(5, 2)
  
  // Lifecycle & Maintenance
  warrantyYears          Int? @map("warranty_years")
  maintenanceCycleYears  Int? @map("maintenance_cycle_years")
  expectedLifespanYears  Int? @map("expected_lifespan_years")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("material_technical_specs")
  @@index([materialId], name: "idx_tech_specs_material")
}

model PricingData {
  id         Int      @id @default(autoincrement())
  materialId Int      @map("material_id")
  
  // Pricing
  pricePerUnit Decimal @map("price_per_unit") @db.Decimal(10, 2)
  unit         String  @db.VarChar(50)
  currency     String  @default("USD") @db.VarChar(3)
  
  // Regional Context
  state   String? @db.VarChar(2)
  city    String? @db.VarChar(100)
  zipCode String? @map("zip_code") @db.VarChar(10)
  county  String? @db.VarChar(100)
  
  // Data Source
  source         String    @db.VarChar(50)
  sourceDate     DateTime? @map("source_date")
  sourceUrl      String?   @map("source_url") @db.Text
  projectName    String?   @map("project_name") @db.VarChar(255)
  contractNumber String?   @map("contract_number") @db.VarChar(100)
  
  // Labor Pricing
  laborRatePerHour Decimal? @map("labor_rate_per_hour") @db.Decimal(8, 2)
  totalLaborCost   Decimal? @map("total_labor_cost") @db.Decimal(10, 2)
  
  // Metadata
  dataConfidence Int       @default(50) @map("data_confidence")
  isActive       Boolean   @default(true) @map("is_active")
  expiresAt      DateTime? @map("expires_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pricing_data")
  @@index([materialId], name: "idx_pricing_material")
  @@index([state], name: "idx_pricing_state")
  @@index([source], name: "idx_pricing_source")
  @@index([isActive], name: "idx_pricing_active")
}

model SwapValidation {
  id                     Int      @id @default(autoincrement())
  
  // Materials
  incumbentMaterialId    Int      @map("incumbent_material_id")
  sustainableMaterialId  Int      @map("sustainable_material_id")
  projectId              Int?     @map("project_id")
  
  // Validation Results
  validationStatus       String   @map("validation_status") @db.VarChar(20) // APPROVED, EXPERIMENTAL, REJECTED
  overallScore           Decimal  @map("overall_score") @db.Decimal(5, 2)
  
  // Showstopper Results (JSON object with all check details)
  showstopperResults     Json     @map("showstopper_results")
  
  // Check Counts
  passedChecks           Int      @map("passed_checks")
  failedChecks           Int      @map("failed_checks")
  skippedChecks          Int      @map("skipped_checks")
  
  // Recommendation
  recommendation         String   @db.Text
  
  // Cost Comparison
  incumbentTotalCost     Decimal? @map("incumbent_total_cost") @db.Decimal(10, 2)
  sustainableTotalCost   Decimal? @map("sustainable_total_cost") @db.Decimal(10, 2)
  costDeltaPercentage    Decimal? @map("cost_delta_percentage") @db.Decimal(5, 2)
  
  // Carbon Comparison
  incumbentGwp           Decimal? @map("incumbent_gwp") @db.Decimal(10, 2)
  sustainableGwp         Decimal? @map("sustainable_gwp") @db.Decimal(10, 2)
  carbonReductionPercentage Decimal? @map("carbon_reduction_percentage") @db.Decimal(5, 2)
  
  // Generated Documentation
  csiFormUrl             String?   @map("csi_form_url") @db.Text
  csiFormGeneratedAt     DateTime? @map("csi_form_generated_at")
  
  // Validation Metadata
  validatedAt            DateTime  @default(now()) @map("validated_at")
  expiresAt              DateTime? @map("expires_at")
  
  // User Tracking
  requestedBy            Int?      @map("requested_by")
  rfqId                  Int?      @map("rfq_id")
  
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@map("swap_validations")
  @@index([incumbentMaterialId], name: "idx_swap_incumbent")
  @@index([sustainableMaterialId], name: "idx_swap_sustainable")
  @@index([validationStatus], name: "idx_swap_status")
  @@index([projectId], name: "idx_swap_project")
}

model MaterialAssemblySpec {
  id                   Int      @id @default(autoincrement())
  
  // Assembly Identity
  name                 String   @db.VarChar(255)
  category             String   @db.VarChar(100)
  description          String?  @db.Text
  
  // Assembly-Level Specs
  totalThicknessInches Decimal? @map("total_thickness_inches") @db.Decimal(5, 2)
  totalRValue          Decimal? @map("total_r_value") @db.Decimal(5, 2)
  fireRating           String?  @map("fire_rating") @db.VarChar(50)
  ulDesignNumber       String?  @map("ul_design_number") @db.VarChar(50)
  stcRating            Int?     @map("stc_rating")
  iicRating            Int?     @map("iic_rating")
  
  // Cost & Carbon
  totalCostPerSf       Decimal? @map("total_cost_per_sf") @db.Decimal(10, 2)
  totalGwpPerSf        Decimal? @map("total_gwp_per_sf") @db.Decimal(10, 2)
  
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  
  components           AssemblySpecComponent[]

  @@map("material_assembly_specs")
  @@index([category], name: "idx_assembly_specs_category")
  @@index([ulDesignNumber], name: "idx_assembly_specs_ul")
}

model AssemblySpecComponent {
  id               Int      @id @default(autoincrement())
  assemblySpecId   Int      @map("assembly_spec_id")
  materialId       Int      @map("material_id")
  layerOrder       Int      @map("layer_order")
  layerName        String   @db.VarChar(255)
  quantity         Decimal  @db.Decimal(8, 2)
  unit             String   @db.VarChar(50)
  thicknessInches  Decimal? @map("thickness_inches") @db.Decimal(5, 2)
  
  createdAt        DateTime @default(now()) @map("created_at")
  
  assembly         MaterialAssemblySpec @relation(fields: [assemblySpecId], references: [id])

  @@map("assembly_spec_components")
  @@index([assemblySpecId], name: "idx_assembly_comp_assembly")
  @@index([materialId], name: "idx_assembly_comp_material")
}
