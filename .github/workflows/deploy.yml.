name: Deploy to Azure

on:
  push:
    branches: [main]

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - uses: azure/login@v1
        with:
          creds: ${{ secrets.AZURE_CREDENTIALS }}
      
      - name: Deploy to Container App
        run: |
          az containerapp up \
            --name greenchainz-container \
            --resource-group rg-greenchainz-prod-container \
            --source . \
            --ingress external \
            --target-port 3000
